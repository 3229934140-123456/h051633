print("=== GC Disabled Test ===");

// This tests nested table creation without GC to confirm the crash is GC-related
let n = 0;
while (n < 2000) {
    let outer = {};
    outer.inner = {};
    outer.inner.data = {};
    outer.inner.data.x = 42;
    n = n + 1;
    if (n % 500 == 0) {
        print("  Created", n, "nested tables...");
    }
}
print("2000 nested tables done (no GC).");

print("=== Test Complete ===");
